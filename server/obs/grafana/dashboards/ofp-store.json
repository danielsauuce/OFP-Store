{
  "id": null,
  "uid": "ofp-store-main",
  "title": "OFP Store — Server Overview",
  "tags": ["ofp", "nodejs"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{route}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Response Time P95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (5xx/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status_code=~\"5..\"}[1m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Orders Created (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(orders_total)",
          "legendFormat": "Orders"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Socket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(active_socket_connections)",
          "legendFormat": "Connections"
        }
      ]
    }
  ]
}
